# ══════════════════════════════════════════════════════════════
# servers.yaml — 多机分布式配置模板
# 主控机：在此机器上运行 distributed_dispatch.py
# ══════════════════════════════════════════════════════════════
#
# 前置准备（每台机器都要做）：
#   1. 开启 WSL2 的 SSH 服务：
#        sudo apt install -y openssh-server
#        sudo service ssh start
#
#   2. 获取 WSL2 IP（或用 Windows IP + 端口转发）：
#        hostname -I   # 在 WSL2 内执行，取第一个 IP
#
#   3. 配置免密登录（在主控机的 WSL2 里执行）：
#        ssh-keygen -t ed25519 -C "pipeline"
#        ssh-copy-id -i ~/.ssh/id_ed25519.pub -p 2222 <用户名>@<目标机器IP>
#
#   4. 共享存储：所有机器必须将共享目录挂载到相同路径
#        sudo mount -t cifs //<NAS_IP>/movies /mnt/movies -o credentials=/etc/smbcredentials
#
# ── WSL2 IP 稳定化（强烈推荐）────────────────────────────────
# 在 Windows 11 %USERPROFILE%\.wslconfig 里加：
#   [wsl2]
#   networkingMode=mirrored   # WSL2 直接使用 Windows 网卡 IP，不再每次重启变化
#
# 或用 Windows 端口转发（PowerShell 管理员）：
#   netsh interface portproxy add v4tov4 listenport=2222 listenaddress=0.0.0.0 `
#     connectport=22 connectaddress=(wsl hostname -I).split()[0]
# ══════════════════════════════════════════════════════════════

servers:

  # ── 远端机器 1 ───────────────────────────────────────────────
  - name: GPU_SERVER_1          # 机器标识，随意命名，用于日志和 --target 参数
    host: 192.168.x.x           # Windows 局域网 IP（固定），或 WSL2 IP
    port: 2222                  # SSH 端口（端口转发方案填 2222，mirrored 方案填 22）
    user: <用户名>               # WSL2 的 Linux 用户名
    ssh_key: ~/.ssh/id_ed25519
    gpus: [0]                   # CUDA 设备 ID 列表
    weight: 1.3                 # 算力权重（相对值），影响抢任务比例
    conda_env: movietest        # conda 环境名
    remote_script: ~/video_pipeline/process_videos.py
    git_repo: ~/video_pipeline  # git pull 时的仓库目录

  # ── 远端机器 2 ───────────────────────────────────────────────
  - name: GPU_SERVER_2
    host: 192.168.x.x
    port: 2222
    user: <用户名>
    ssh_key: ~/.ssh/id_ed25519
    gpus: [0]
    weight: 1.5
    conda_env: movietest
    remote_script: ~/video_pipeline/process_videos.py
    git_repo: ~/video_pipeline

  # ── 主控机自身（可选，白天不用时注释掉整个块）───────────────
  - name: LOCAL_GPU
    host: localhost              # 主控机自己，不走 SSH
    port: 22
    user: <用户名>               # 主控机的 WSL2 用户名
    ssh_key: ~/.ssh/id_ed25519
    gpus: [0]
    weight: 1.0
    conda_env: movietest
    remote_script: ~/video_pipeline/process_videos.py
    git_repo: ~/video_pipeline

# ══════════════════════════════════════════════════════════════
# 常用命令速查：
#
# 启动全部机器：
#   python distributed_dispatch.py \
#     --input-dir /mnt/movies/Films \
#     --output-dir /mnt/movies/Films/output \
#     --servers servers.yaml
#
# 查看状态：
#   python distributed_dispatch.py \
#     --servers servers.yaml --output-dir /mnt/movies/Films/output --status
#
# 停止全部：
#   python distributed_dispatch.py --servers servers.yaml --stop
#
# 停止单台：
#   python distributed_dispatch.py --servers servers.yaml --stop --target GPU_SERVER_1
#
# 只启动某台：
#   python distributed_dispatch.py ... --servers servers.yaml --target GPU_SERVER_2
# ══════════════════════════════════════════════════════════════
