# ═══════════════════════════════════════════════════════════════
# Runpod Stage 5 标注配置（32B 默认模板）
# 拷贝到 configs/runpod.yaml 后填入真实 Pod 信息
# 真实 runpod.yaml 已在 .gitignore 里，不会误提交
#
# 切换模型：
#   - 32B Qwen3-VL（当前文件）：1× H100 80GB 即可跑
#   - 122B Qwen3.5-AWQ：参考 configs/runpod.122b.yaml.example
# 调用：
#   python -m src.runpod.upload --config configs/runpod.yaml         # 32B
#   python -m src.runpod.upload --config configs/runpod.122b.yaml    # 122B
# ═══════════════════════════════════════════════════════════════

pod:
  host: 157.66.254.40         # Runpod Pod 公网 IP
  port: 22100                # Pod SSH 端口（Runpod 网页 connect 面板里能拿到）
  user: 14562               # Runpod Pod 默认用户
  ssh_key: ~/.ssh/id_ed25519 # 你添加到 Runpod 账号的 SSH 私钥

paths:
  local_clips_root:   /mnt/movies/Films/output/clips       # Stage 2 的输出
  local_labels_root:  /mnt/movies/Films/output/labels      # 标注 JSON 本地落地位置
  local_manifest_dir: /mnt/movies/Films/output/manifest    # Stage 4 输出的 manifest JSONL 目录
  pod_workspace:      /workspace/labeling                  # Pod 内工作目录（~200GB 磁盘）

model:
  name: Qwen/Qwen3-VL-32B-Instruct
  precision: bf16            # bf16 (~64 GB，H100 80G OK) | fp8 (~35 GB) | awq | awq_marlin | gptq-int4
  # 仅 AWQ / GPTQ 需要；bf16/fp8 留 null（vLLM 自动推导）
  quantization: null
  # 本地预下载路径（可选）；为 null 时 vLLM 走 HuggingFace hub
  # 建议路径：/workspace/models/qwen3-vl-32b-instruct
  path: null
  # 3 轮推理每轮独立 context。H100 80GB + 32B BF16 (~64GB weights) + util=0.9 时
  # KV cache 只剩 ~4.3 GB，够 16384 token（实测 vLLM 自算上限 17616）；20480 会
  # ValueError: "KV cache memory (4.3 GiB) < needed (5.0 GiB)"。H200 141GB 可放宽。
  max_model_len: 16384
  gpu_memory_utilization: 0.92  # 0.9 → 0.92 多挤 ~0.8 GB 给 KV；bf16 建议 ≤0.94
  # 原生 video 模式下 vLLM 内部会把视频切成多图：image 给大，video=1 每次发 1 个视频
  limit_mm_per_prompt:
    image: 64
    video: 1
  # 多卡推理（32B 单卡足够；122B 有时要 2）。设 1 = 单卡
  tensor_parallel_size: 1
  # CUDA graph：32B 稳，false 即可；OOM 时改 true 省 2-3 GB 但慢 10-15%
  enforce_eager: false
  # 并发请求数：小批量 2-4 够；vLLM 默认 256 会过度预留 KV
  max_num_seqs: 4

filters:
  shot_categories: [single, dominant]   # 先只跑人物特写；改成 [] 则不过滤
  movies: []                            # [] = 所有电影；或列出 ["MovieA","MovieB"]
  max_shots: null                       # 调试时填数字限制前 N 条，null = 全部

sampling:
  temperature:           0.2
  top_p:                 0.9
  repetition_penalty:    1.05
  # ── 三轮推理的 output 预算（R3 scene / R2 persons+face / R1 per-person body）──
  # 2026-04-20 重构：R3→R2→R1-per-person 顺序 + R1 拆成 N 次 per-person 调用
  # 必须满足 input + output ≤ max_model_len (16384)：
  #   R3：video ~6K + system 800 + hint 500 + out 3072 ≈ 10.4K ✓
  #   R2：video ~6K + system 800 + crops 1.6K + hint 2.5K + out 4096 ≈ 15K ✓
  #   R1_per_person：video ~6K + system 800 + hint 1200 + out 4096 ≈ 12.1K ✓
  # R1 per-person 每次只出 1 人 body (~3K tok) → 不会被 N 人膨胀撑爆。
  # N=3 shot 跑 3 次 R1，vLLM prefix caching 让 video embed 只算一次。
  max_tokens_round1:     4096
  max_tokens_round2:     4096
  max_tokens_round3:     3072
  # 兼容旧单轮路径（暂时保留）
  max_tokens:            8192

  # ══════════════════════════════════════════════════════════════
  # 采帧 & 视频输入（核心质量参数）
  # ══════════════════════════════════════════════════════════════
  # video_mode: true  → 发 video_url 给 vLLM，让 Qwen3-VL 自己按 fps 采样
  #                     + 插时间戳 token，时序推理最强，长短 shot 统一
  #             false → 老路径：自己用 decord 采固定帧数后发 image_url 列表
  video_mode: true
  # vLLM 内部采样 fps；Qwen3-VL 默认 sample_fps=2。
  # 2026-04-20 重构：R3→R2→R1-per-person 架构下，R1 每次只出 1 人 body
  # (~3K tok output 够用)，不再被 N 人膨胀撑爆 max_model_len。因此可以把
  # video_fps 提到 8，换取更高时间分辨率（5s shot = 40 帧 ≈ 6K tok video
  # embed，单轮 input 约 9K，R1_per_person output 3K → 总 ~12K < 16K）。
  # 动作/表情细粒度显著提升。
  video_fps: 8
  # 单帧像素预算（控制每帧 token 数）。Qwen3-VL 用 28×28 patch + 4-neighbor merge：
  #   256×256 ≈ 65 tok；336×336 ≈ 150 tok；448×448 ≈ 265 tok
  video_max_pixels: 112896          # 336×336 上限
  video_min_pixels: 50176           # 224×224 下限（vLLM 会自动缩到此范围）

  # ── Face crop 附加（Round 2 高分辨率细节）──
  # Pod 侧用 Stage 4 的 YOLO/Haar 在采样帧上检测脸，裁 224px 送 R2
  # 效果：VLM 能看清眼眉嘴，facial_components / blendshape_hints 显著提升
  face_crop_enabled: true
  face_crop_size: 224               # 裁到 224×224
  face_crop_per_frame_max: 4        # 每帧最多保留 4 张脸（按面积降序）
  face_crop_sample_fps: 2           # 裁脸帧率（不用 5，2 足够覆盖表情动态）
  face_detector: haar               # haar (cv2 内置) | yolo_face (需 yolov8n-face.pt)

  # ── 老路径参数（video_mode=false 时使用）──
  frames_single_dominant: 8
  frames_multi_wide:      4
  resize_shortest:        448

  # ── 合规开关 ──
  # 32B dense 模型的 structured outputs 稳定，不需要逃生口
  disable_structured_output: false
  disable_schema_validation: false
