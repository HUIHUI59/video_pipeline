# ═══════════════════════════════════════════════════════════════
# Runpod Stage 5 标注配置（32B 默认模板）
# 拷贝到 configs/runpod.yaml 后填入真实 Pod 信息
# 真实 runpod.yaml 已在 .gitignore 里，不会误提交
#
# 切换模型：
#   - 32B Qwen3-VL（当前文件）：1× H100 80GB 即可跑
#   - 122B Qwen3.5-AWQ：参考 configs/runpod.122b.yaml.example
# 调用：
#   python -m src.runpod.upload --config configs/runpod.yaml         # 32B
#   python -m src.runpod.upload --config configs/runpod.122b.yaml    # 122B
# ═══════════════════════════════════════════════════════════════

pod:
  host: 157.66.254.40         # Runpod Pod 公网 IP
  port: 22100                # Pod SSH 端口（Runpod 网页 connect 面板里能拿到）
  user: 14562               # Runpod Pod 默认用户
  ssh_key: ~/.ssh/id_ed25519 # 你添加到 Runpod 账号的 SSH 私钥

paths:
  local_clips_root:   /mnt/movies/Films/output/clips       # Stage 2 的输出
  local_labels_root:  /mnt/movies/Films/output/labels      # 标注 JSON 本地落地位置
  local_manifest_dir: /mnt/movies/Films/output/manifest    # Stage 4 输出的 manifest JSONL 目录
  pod_workspace:      /workspace/labeling                  # Pod 内工作目录（~200GB 磁盘）

model:
  name: Qwen/Qwen3-VL-32B-Instruct
  precision: bf16            # bf16 (~66.7 GB，H100 80G OK) | fp8 (~35 GB) | awq | awq_marlin | gptq-int4
  # 仅 AWQ / GPTQ 需要；bf16/fp8 留 null（vLLM 自动推导）
  quantization: null
  # 本地预下载路径（可选）；为 null 时 vLLM 走 HuggingFace hub
  path: null
  # Qwen3-VL-32B 原生 max_seq_len=262144（会要求 64GB KV cache，H100 80G 装不下）。
  # 我们单 shot 实际用量 ~16K token 就够：system~800 + user~1600 + 8帧×1500 + out 2048
  max_model_len: 16384
  gpu_memory_utilization: 0.9   # vLLM 可用的显存比例。bf16 用到 0.9 较稳；fp8 可以调到 0.95
  # 每次 chat 允许的图片上限（32B 可 16；122B 建议 8 以节省 KV）
  limit_mm_per_prompt:
    image: 16
  # 多卡推理（32B 单卡足够；122B 有时要 2）。设 1 = 单卡
  tensor_parallel_size: 1

filters:
  shot_categories: [single, dominant]   # 先只跑人物特写；改成 [] 则不过滤
  movies: []                            # [] = 所有电影；或列出 ["MovieA","MovieB"]
  max_shots: null                       # 调试时填数字限制前 N 条，null = 全部

sampling:
  temperature:           0.2
  top_p:                 0.9
  # 两轮推理分别的 output 预算（方案 E，见 docs/problem/01_stage5_output_truncation.md）
  # 3 人 shot 的 body_analysis 一个人 ~3000 token，pretty-print 又吃 40%，给 10240 留足
  max_tokens_round1:     10240
  max_tokens_round2:     10240
  max_tokens:            10240  # 兼容旧路径（如果以后回退单轮）
  repetition_penalty:    1.05
  frames_single_dominant: 8   # single / dominant 采 8 帧
  frames_multi_wide:      4   # multi / wide / landscape 采 4 帧
  resize_shortest:        448 # Qwen3-VL 推荐短边
